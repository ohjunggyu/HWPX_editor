# HWPX Editor Environment Settings

# -----------------
# 1. API Server (FastAPI)
# -----------------
# HWPX 엔진이 구동되는 백엔드 서버 주소입니다.
API_HOST=http://127.0.0.1:8000

# -----------------
# 2. LLM Settings (Ollama)
# -----------------
# 대화를 처리하고 양식을 채울 로컬 LLM 서버 주소를 입력하세요.
# (기본 Ollama 포트는 보통 11434 이나, 사용자 설정에 따라 다를 수 있습니다)
OLLAMA_URL=http://localhost:11435/api/chat

# 사용할 모델명 (권장: gemma3:12b, qwen2.5:32b 등)
OLLAMA_MODEL=gemma3:12b

# -----------------
# 3. Development
# -----------------
# debug 폴더에 파싱 결과 및 LLM 응답/요청 전체 JSON 로그를 남길지 설정 (true/false)
DEBUG=true
